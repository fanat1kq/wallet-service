<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="create-table-wallets" author="fanat1kq">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="wallets"/>
            </not>
        </preConditions>

        <createTable tableName="wallets" remarks="Table for managing wallets ">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="balance" remarks="Balance of wallt" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" remarks="Time of creating"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified_at" type="timestamp with time zone" remarks="Time of modifying"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>